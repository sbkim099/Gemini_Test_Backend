<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="Board">
  
  <select id="countAllPosts" resultType="int">
  	select count(*) from board
  </select>
  
  <select id="getStartEnd" resultType="com.study.app.domains.board.BoardDTO">
  	select * from (select board.*, row_number()over(order by seq desc) rn from board) where rn between #{start} and #{end}
  </select>
  
  <select id="getPostDetail" resultType="com.study.app.domains.board.BoardDTO">
  	select * from board where seq = #{seq}
  </select>
  
  <insert id="insert">
  	insert into board values(board_seq.nextval, #{writer}, #{title}, #{contents}, 0, sysdate)
  </insert>
  
  <update id="updatePost">
  	update board set title = #{title}, contents = #{contents} where seq = #{seq}
  </update>
  
  <delete id="deletePost">
  	delete from board where seq = #{seq}
  </delete>
</mapper>